# Copy this file to .env and fill in your values
#
#   cp .env.example .env
#
# For production/EC2, use .env.production.example instead.

# ── AI Chat (Groq — required for the /chat page) ──────────────────────────────
# The AI Chat Assistant calls the Groq API over the internet.
# All other features (dashboard, ML anomaly detection, forecasting) work without it.
#
# Get a FREE API key (no credit card needed) at: https://console.groq.com
# 1. Sign in with GitHub
# 2. API Keys → Create API Key
# 3. Paste the key below
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Application ───────────────────────────────────────────────────────────────
APP_PORT=5000
APP_REPLICA_PORT=5001
FLASK_ENV=development
ML_ENABLED=true

# ── Bot Configuration ─────────────────────────────────────────────────────────
BOT_POLL_SECONDS=5
CPU_THRESHOLD=80
ERROR_RATE_THRESHOLD=0.2
RESPONSE_TIME_THRESHOLD_MS=500

# ── Remediation Settings ──────────────────────────────────────────────────────
MAX_RESTARTS_PER_5MIN=3
COOLDOWN_SECONDS=120
ENABLE_AUTO_SCALE=true

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=remediation_user
POSTGRES_PASSWORD=remediation_pass
POSTGRES_DB=remediation_db
DATABASE_URL=postgresql://remediation_user:remediation_pass@postgres:5432/remediation_db

# ── Data Retention ────────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=180
CLEANUP_INTERVAL_HOURS=24

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin   # change this to something secure

# ── Slack Notifications (optional) ───────────────────────────────────────────
# Leave empty to disable — the bot will log notifications to console only.
# Get a webhook URL from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
