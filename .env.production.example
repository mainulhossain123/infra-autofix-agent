# =============================================================================
# infra-autofix-agent — PRODUCTION Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values marked with <CHANGE_ME>
#
#   cp .env.production.example .env
#   nano .env
#
# To generate a strong random password, run:
#   openssl rand -base64 24
# =============================================================================

# --- Application ---
FLASK_ENV=production
APP_PORT=5000

# --- Database (CHANGE ALL PASSWORDS) ---
POSTGRES_USER=remediation_user
POSTGRES_PASSWORD=<CHANGE_ME_strong_db_password>
POSTGRES_DB=remediation_db
DATABASE_URL=postgresql://remediation_user:<CHANGE_ME_strong_db_password>@postgres:5432/remediation_db

# --- Grafana (CHANGE PASSWORD) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=<CHANGE_ME_grafana_password>
GRAFANA_PORT=3001

# --- Bot Behavior ---
BOT_POLL_SECONDS=5
CPU_THRESHOLD=80
ERROR_RATE_THRESHOLD=0.2
RESPONSE_TIME_THRESHOLD_MS=500
MAX_RESTARTS_PER_5MIN=3
COOLDOWN_SECONDS=120
ENABLE_AUTO_SCALE=true

# --- Data Retention ---
DATA_RETENTION_DAYS=180
CLEANUP_INTERVAL_HOURS=24

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Slack Notifications (optional) ---
# Get your webhook URL from: https://api.slack.com/messaging/webhooks
# Leave empty to disable notifications (bot will log to console only)
SLACK_WEBHOOK_URL=

# --- AI Chat (Groq — free API, replaces Ollama on free-tier deployments) ---
# Get your free key at: https://console.groq.com
GROQ_API_KEY=<CHANGE_ME_groq_api_key>
GROQ_MODEL=llama-3.3-70b-versatile
ML_ENABLED=true
